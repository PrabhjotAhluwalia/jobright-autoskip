{
  "manifest_version": 3,
  "name": "JobRight Auto-Skip",
  "version": "1.4.0",
  "description": "Skips autofill-only prompts, auto-detects submissions, and fills OTPs from Gmail",
  "key": "",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "identity",
    "alarms"
  ],
  "host_permissions": [
    "https://jobright.ai/*",
    "https://gmail.googleapis.com/*",
    "https://www.googleapis.com/*",
    "https://accounts.google.com/*",
    "https://oauth2.googleapis.com/*",
    "http://127.0.0.1:17373/*",
    "https://*.lever.co/*",
    "https://*.greenhouse.io/*",
    "https://*.ashbyhq.com/*",
    "https://*.myworkdayjobs.com/*",
    "https://*.myworkdaysite.com/*",
    "https://*.smartrecruiters.com/*",
    "https://*.icims.com/*",
    "https://*.jobvite.com/*",
    "https://*.workable.com/*",
    "https://*.bamboohr.com/*",
    "https://*.oraclecloud.com/*",
    "https://*.successfactors.com/*",
    "https://*.successfactors.eu/*",
    "https://*.applytojob.com/*",
    "https://*.recruitee.com/*",
    "https://*.teamtailor.com/*",
    "https://*.ultipro.com/*",
    "https://*.breezy.hr/*",
    "https://*.rippling.com/*",
    "https://*.pinpointhq.com/*",
    "https://*.comeet.com/*",
    "https://*.taleo.net/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' http://127.0.0.1:17373 https://accounts.google.com https://oauth2.googleapis.com https://gmail.googleapis.com https://www.googleapis.com;"
  },
  "content_scripts": [
    {
      "matches": [
        "https://jobright.ai/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.lever.co/*",
        "https://*.greenhouse.io/*",
        "https://*.ashbyhq.com/*",
        "https://*.myworkdayjobs.com/*",
        "https://*.myworkdaysite.com/*",
        "https://*.smartrecruiters.com/*",
        "https://*.icims.com/*",
        "https://*.jobvite.com/*",
        "https://*.workable.com/*",
        "https://*.bamboohr.com/*",
        "https://*.oraclecloud.com/*",
        "https://*.successfactors.com/*",
        "https://*.successfactors.eu/*",
        "https://*.applytojob.com/*",
        "https://*.recruitee.com/*",
        "https://*.teamtailor.com/*",
        "https://*.ultipro.com/*",
        "https://*.breezy.hr/*",
        "https://*.rippling.com/*",
        "https://*.pinpointhq.com/*",
        "https://*.comeet.com/*",
        "https://*.taleo.net/*"
      ],
      "js": [
        "ats_content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/Prabhjot_Ahluwalia_PM_Resume_US_Citizen.pdf",
        "jobright_excluded_job_titles.txt",
        "jobright_excluded_job_title_regexes.txt",
        "jobright_terminal_success_phrases.txt"
      ],
      "matches": [
        "https://jobright.ai/*",
        "https://*.lever.co/*",
        "https://*.greenhouse.io/*",
        "https://*.ashbyhq.com/*",
        "https://*.myworkdayjobs.com/*",
        "https://*.myworkdaysite.com/*",
        "https://*.smartrecruiters.com/*",
        "https://*.icims.com/*",
        "https://*.jobvite.com/*",
        "https://*.workable.com/*",
        "https://*.bamboohr.com/*",
        "https://*.oraclecloud.com/*",
        "https://*.successfactors.com/*",
        "https://*.successfactors.eu/*",
        "https://*.applytojob.com/*",
        "https://*.recruitee.com/*",
        "https://*.teamtailor.com/*",
        "https://*.ultipro.com/*",
        "https://*.breezy.hr/*",
        "https://*.rippling.com/*",
        "https://*.pinpointhq.com/*",
        "https://*.comeet.com/*",
        "https://*.taleo.net/*"
      ]
    }
  ],
  "oauth2": {
    "client_id": "135352106535-jt4etr4ag7k3he3gv9fe3si0dqisecfr.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/gmail.modify",
      "https://www.googleapis.com/auth/gmail.send"
    ]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "JobRight Auto-Skip",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
